rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Price logs are server-managed only (Admin SDK).
    match /product_price_logs/{docId} {
      allow read, write: if false;
    }

    // Sync run logs are server-managed only (Admin SDK).
    match /price_sync_runs/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
